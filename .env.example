# ===========================================
# AutoGen API 配置文件示例
# 使用说明：复制此文件为 .env 并填入实际值
# ===========================================

# OpenAI API 配置
OPENAI_API_TYPE=openai
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_VERSION=2024-02-15-preview

# Azure OpenAI 配置（如使用 Azure）
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_API_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# 模型配置
CHAT_COMPLETION_MODEL=gpt-4o
CHAT_COMPLETION_MODEL_FAMILY=gpt-4o

# ===========================================
# Magentic-One 配置
# ===========================================

# 任务配置
MAX_ROUNDS=30
MAX_TIME_SECONDS=1500
MAX_STALLS_BEFORE_REPLAN=10
MAX_REPLANS=3

# 浏览器配置
BROWSER_HEADLESS=true
BROWSER_CHANNEL=chromium

# ===========================================
# 日志配置
# ===========================================

LOG_LEVEL=INFO
LOG_FILE=./logs/autogen.log

# ===========================================
# 其他配置
# ===========================================

# 是否启用人机交互模式
HIL_MODE=false

# 是否保存截图
SAVE_SCREENSHOTS=false

# 工作目录
WORK_DIR=./workspace
