# ===========================================
# 小米 MiMo API 配置文件示例
# 使用说明：复制此文件为 .env 并填入实际值
# ===========================================

# API 类型：xiaomi-mimo
API_TYPE=xiaomi-mimo

# 小米 MiMo API 配置
# 按量付费 Base URL
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# Token Plan 用户请使用以下地址（二选一）：
# 国内：https://token-plan-cn.xiaomimimo.com/v1
# 海外：https://token-plan-ams.xiaomimimo.com/v1

# API Key（按量付费格式：sk-xxxxx，Token Plan格式：tp-xxxxx）
MIMO_API_KEY=your_mimo_api_key_here

# 模型配置
MIMO_MODEL=mimo-v2.5-pro
MIMO_MODEL_FAMILY=gpt-4o

# 其他可用模型：
# mimo-v2.5-pro (旗舰版，1.02T参数 MoE)
# mimo-v2.5
# mimo-v2-flash

# ===========================================
# AutoGen 框架配置
# ===========================================

# 兼容 OpenAI 协议的配置
OPENAI_API_KEY=${MIMO_API_KEY}
OPENAI_API_BASE=${MIMO_BASE_URL}
OPENAI_API_TYPE=openai

# Chat Completion 配置
CHAT_COMPLETION_CLIENT_CONFIG={"provider":"azure_openai_chat_completion_client","config":{"model":"mimo-v2.5-pro","azure_endpoint":"https://api.xiaomimimo.com/v1","api_key":"${MIMO_API_KEY}","api_version":"2024-06-01"}}

# ===========================================
# Magentic-One 配置
# ===========================================

# 任务配置
MAX_ROUNDS=30
MAX_TIME_SECONDS=1500
MAX_STALLS_BEFORE_REPLAN=10
MAX_REPLANS=3

# 浏览器配置
BROWSER_HEADLESS=true
BROWSER_CHANNEL=chromium

# ===========================================
# 日志配置
# ===========================================

LOG_LEVEL=INFO
LOG_FILE=./logs/autogen.log

# ===========================================
# 其他配置
# ===========================================

# 是否启用人机交互模式
HIL_MODE=false

# 是否保存截图
SAVE_SCREENSHOTS=false

# 工作目录
WORK_DIR=./workspace
